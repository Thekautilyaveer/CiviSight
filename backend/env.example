# Server
PORT=5001
NODE_ENV=production

# Data store selector: 'supabase' (default) or 'mongo' (rollback)
DATA_DRIVER=supabase

# Database (MongoDB — required only when DATA_DRIVER=mongo; kept as fallback)
MONGODB_URI=mongodb://localhost:27017/civisight

# Supabase Postgres (required when DATA_DRIVER=supabase). Session pooler connection string.
SUPABASE_DB_URL=postgresql://postgres.<project>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-this

# Email
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-app-password
EMAIL_TO=admin@civisight.org

# Frontend
FRONTEND_URL=https://yourdomain.com

# AWS S3 Configuration (Optional - files are stored locally by default)
# Uncomment and configure if you want to use AWS S3 instead of local storage
# AWS_ACCESS_KEY_ID=your-aws-access-key-id
# AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
# AWS_REGION=us-east-1
# AWS_S3_BUCKET=your-bucket-name